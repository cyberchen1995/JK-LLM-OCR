{
  "identifier": "io.github.gravitypoet.jk.llm.ocr",
  "version": "0.2.9",
  "category": "ocr",
  "name": "JK-LLM-OCR (Local + Cloud)",
  "summary": "最强OCR插件（本地 + 云端服务商 + 百度 jobs）",
  "icon": "",
  "author": "JK-LLM-OCR Contributors",
  "homepage": "https://github.com/GravityPoet/JK-LLM-OCR",
  "appcast": "https://raw.githubusercontent.com/GravityPoet/JK-LLM-OCR/main/appcast.json",
  "minBobVersion": "1.8.0",
  "options": [
    {
      "identifier": "serviceMode",
      "type": "menu",
      "title": "[模式] OCR 服务模式",
      "defaultValue": "local",
      "isKeyOption": true,
      "menuValues": [
        {
          "title": "本地服务",
          "value": "local",
          "defaultPluginName": "JK-LLM-OCR (Local + Cloud)"
        },
        {
          "title": "云端服务商 OCR（OpenAI兼容）",
          "value": "providerCloud",
          "defaultPluginName": "JK-LLM-OCR (Local + Cloud)"
        },
        {
          "title": "百度异步文档解析 jobs",
          "value": "cloudAsync",
          "defaultPluginName": "JK-LLM-OCR (Local + Cloud)"
        }
      ],
      "desc": "已简化为 3 种模式：本地、本地外部服务商(OpenAI兼容)、百度异步 jobs。只填写当前模式对应的那一组字段。"
    },
    {
      "identifier": "localServerUrl",
      "type": "text",
      "title": "[本地] OCR 服务地址",
      "defaultValue": "http://127.0.0.1:50000/ocr",
      "desc": "仅本地模式使用。填写你自己的 HTTP /ocr 地址，例如本机或 VPS 隧道地址。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "http://127.0.0.1:50000/ocr"
      }
    },
    {
      "identifier": "cloudApiKey",
      "type": "text",
      "title": "[云端服务商] API Key",
      "defaultValue": "",
      "desc": "仅“云端服务商 OCR”模式使用。",
      "textConfig": {
        "type": "secure",
        "placeholderText": "sk-xxxxxxxxxxxxxxxxxxxxxxxx"
      }
    },
    {
      "identifier": "cloudBaseUrl",
      "type": "text",
      "title": "[云端服务商] Base URL",
      "defaultValue": "https://api.siliconflow.cn/v1",
      "desc": "仅云端服务商 OCR 模式使用。支持填根地址或完整 /chat/completions。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "https://api.siliconflow.cn/v1"
      }
    },
    {
      "identifier": "cloudModel",
      "type": "text",
      "title": "[云端服务商] 模型名",
      "defaultValue": "PaddlePaddle/PaddleOCR-VL-1.5",
      "desc": "仅云端服务商 OCR 模式使用。可填写任意支持图像输入的 OpenAI 兼容模型名。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "PaddlePaddle/PaddleOCR-VL-1.5"
      }
    },
    {
      "identifier": "cloudImageDetail",
      "type": "menu",
      "title": "[云端服务商] 图像细节",
      "defaultValue": "high",
      "menuValues": [
        {
          "title": "高（识别更稳）",
          "value": "high"
        },
        {
          "title": "自动",
          "value": "auto"
        },
        {
          "title": "低（更省）",
          "value": "low"
        }
      ],
      "desc": "仅云端服务商 OCR 模式使用。映射 image_url.detail。"
    },
    {
      "identifier": "cloudPrompt",
      "type": "text",
      "title": "[云端服务商] OCR 指令",
      "defaultValue": "请识别图片中的全部文字，仅返回纯文本结果，保留原有换行，不要解释。",
      "desc": "仅云端服务商 OCR 模式使用。用于约束模型输出格式。",
      "textConfig": {
        "type": "visible",
        "height": "64",
        "placeholderText": "请识别图片中的全部文字，仅返回纯文本结果，保留原有换行，不要解释。"
      }
    },
    {
      "identifier": "accessToken",
      "type": "text",
      "title": "[百度异步] Access Token",
      "defaultValue": "",
      "desc": "仅百度异步 jobs 模式使用。发送 Authorization: bearer <访问令牌>。",
      "textConfig": {
        "type": "secure",
        "placeholderText": "填写 AI Studio Access Token"
      }
    },
    {
      "identifier": "baiduServerUrl",
      "type": "text",
      "title": "[百度异步] 服务地址",
      "defaultValue": "https://paddleocr.aistudio-app.com/api/v2/ocr",
      "desc": "仅百度异步 jobs 模式使用。填 /jobs 或其根地址，插件会自动标准化。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "https://paddleocr.aistudio-app.com/api/v2/ocr"
      }
    },
    {
      "identifier": "asyncJsonDownloadStrategy",
      "type": "menu",
      "title": "[百度异步] 结果下载策略",
      "defaultValue": "directThenRelay",
      "menuValues": [
        {
          "title": "只走直连",
          "value": "directOnly"
        },
        {
          "title": "直连失败回退 Relay",
          "value": "directThenRelay"
        },
        {
          "title": "只走 Relay",
          "value": "relayOnly"
        }
      ],
      "desc": "仅百度异步 jobs 模式使用。公开版默认“直连失败回退 Relay”，兼顾可用性与无需本地 relay 的首次安装体验；若你要排查 Bob 对签名 jsonUrl 的兼容问题，手动切到“只走直连”；若你本机已部署 relay 且只追求稳定，可切到“只走 Relay”。"
    },
    {
      "identifier": "asyncResultRelayUrl",
      "type": "text",
      "title": "[百度异步] Relay 地址(可选)",
      "defaultValue": "http://127.0.0.1:50123/fetch-jsonl",
      "desc": "仅百度异步 jobs 模式使用。仅在“直连失败回退 Relay”或“只走 Relay”时会使用；若当前策略需要 relay，这里不能为空。"
    },
    {
      "identifier": "cloudModelPreset",
      "type": "menu",
      "title": "[百度异步] 模型",
      "defaultValue": "auto",
      "menuValues": [
        {
          "title": "自动检测（推荐）",
          "value": "auto"
        },
        {
          "title": "PaddleOCR-VL-1.5",
          "value": "PaddleOCR-VL-1.5"
        },
        {
          "title": "PaddleOCR-VL",
          "value": "PaddleOCR-VL"
        },
        {
          "title": "自定义模型 ID",
          "value": "custom"
        }
      ],
      "desc": "仅百度异步 jobs 模式使用。Bob 没有动态按钮选项，因此点击插件自带“验证”或实际 OCR 时，会在“自动检测”模式下自动探测当前 token 可用模型。若选“自定义模型 ID”，则读取下面的输入框。"
    },
    {
      "identifier": "cloudCustomModelName",
      "type": "text",
      "title": "[百度异步] 自定义模型 ID",
      "defaultValue": "",
      "desc": "仅当上面的“[百度异步] 模型”选为“自定义模型 ID”时生效。"
    },
    {
      "identifier": "requestTimeoutSec",
      "type": "text",
      "title": "[通用] 请求超时(秒)",
      "defaultValue": "60",
      "desc": "本地 / 云端服务商模式为单次请求超时；百度异步 jobs 模式为提交+轮询总超时，范围 5-180 秒。"
    },
    {
      "identifier": "textRecScoreThresh",
      "type": "text",
      "title": "[本地] 文本置信度阈值",
      "defaultValue": "0.0",
      "desc": "仅本地模式使用。传给 PP-OCRv5 的 textRecScoreThresh，范围 0.0-1.0。"
    },
    {
      "identifier": "useDocOrientationClassify",
      "type": "menu",
      "title": "[本地] 文档方向分类",
      "defaultValue": "false",
      "menuValues": [
        {
          "title": "关闭",
          "value": "false"
        },
        {
          "title": "开启",
          "value": "true"
        }
      ],
      "desc": "仅本地模式使用。"
    },
    {
      "identifier": "useDocUnwarping",
      "type": "menu",
      "title": "[本地] 文档矫正",
      "defaultValue": "false",
      "menuValues": [
        {
          "title": "关闭",
          "value": "false"
        },
        {
          "title": "开启",
          "value": "true"
        }
      ],
      "desc": "仅本地模式使用。"
    },
    {
      "identifier": "useTextlineOrientation",
      "type": "menu",
      "title": "[本地] 文本行方向分类",
      "defaultValue": "false",
      "menuValues": [
        {
          "title": "关闭",
          "value": "false"
        },
        {
          "title": "开启",
          "value": "true"
        }
      ],
      "desc": "仅本地模式使用。"
    },
    {
      "identifier": "useChartRecognition",
      "type": "menu",
      "title": "[百度异步] 图表识别",
      "defaultValue": "false",
      "menuValues": [
        {
          "title": "关闭",
          "value": "false"
        },
        {
          "title": "开启",
          "value": "true"
        }
      ],
      "desc": "仅百度异步 jobs 模式使用。"
    }
  ]
}
